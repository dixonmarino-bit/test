# =============================
# App local
# =============================
PORT=3000

# Cada cuánto hacer reconciliación completa contra Zendesk (ms).
# Recomendado: 60000-300000
REFRESH_INTERVAL_MS=30000

# =============================
# Zendesk API (obligatorio para datos reales)
# =============================
# URL base de tu cuenta Zendesk (sin slash final)
# Ejemplo: https://tuempresa.zendesk.com
ZENDESK_SUBDOMAIN_URL=https://linktic-74833.zendesk.com

# Email del usuario API
ZENDESK_EMAIL=michael.sanchez@linktic.com

# API token de Zendesk
ZENDESK_API_TOKEN=zIHqRpTF0WAik9bBZ23wl9IQ0GKYr6MnWqUUAMPW

# Umbral SLA en minutos para cumplimiento (MVP)
SLA_TARGET_MINUTES=480

# Tickets resueltos máximos a considerar para promedios diarios
MAX_TICKETS_FOR_AVG=200

# Concurrencia máxima de requests salientes a Zendesk
MAX_CONCURRENT_ZENDESK_CALLS=6

# Reintentos para 429/5xx
ZENDESK_MAX_RETRIES=4
ZENDESK_RETRY_BASE_DELAY_MS=500

# =============================
# Webhooks Zendesk (recomendado para casi tiempo real)
# =============================
# Secret compartido para validar firma HMAC del webhook
ZENDESK_WEBHOOK_SECRET=

# Header firma webhook (default Zendesk)
ZENDESK_WEBHOOK_SIGNATURE_HEADER=x-zendesk-webhook-signature

# Header timestamp webhook (si aplica)
ZENDESK_WEBHOOK_TIMESTAMP_HEADER=x-zendesk-webhook-signature-timestamp

# Debounce para agrupar bursts de webhooks antes de reconciliar (ms)
WEBHOOK_DEBOUNCE_MS=1500
